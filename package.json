{
  "name": "tollgate",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:gateway": "turbo run dev --filter=@tollgate/gateway",
    "dev:dashboard": "turbo run dev --filter=@tollgate/dashboard",
